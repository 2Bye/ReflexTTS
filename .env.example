# ──────────────────────────────────────────────
# ReflexTTS Development Environment
# ──────────────────────────────────────────────

# ── vLLM ──
VLLM_BASE_URL=http://vllm:8000/v1
VLLM_MODEL_NAME=Qwen/Qwen3-8B-AWQ
VLLM_MAX_TOKENS=4096
VLLM_TEMPERATURE=0.1

# ── CosyVoice3 ──
COSYVOICE_MODEL_DIR=pretrained_models/Fun-CosyVoice3-0.5B
COSYVOICE_LOAD_VLLM=true
COSYVOICE_LOAD_TRT=true

# ── WhisperX ──
WHISPERX_MODEL_NAME=large-v3
WHISPERX_DEVICE=cuda
WHISPERX_COMPUTE_TYPE=float16

# ── Security ──
SECURITY_MAX_TEXT_LENGTH=1000
SECURITY_MAX_RETRIES=3
SECURITY_ENABLE_PII_MASKING=true

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Logging ──
LOG_LEVEL=DEBUG
LOG_FORMAT=console
LOG_SERVICE_NAME=reflex-tts

# ── API ──
API_HOST=0.0.0.0
API_PORT=8080
